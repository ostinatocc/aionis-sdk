{
  "name": "@aionis/sdk",
  "version": "0.3.1",
  "description": "TypeScript SDK facade for the Aionis state-adjudicated memory Runtime.",
  "license": "Apache-2.0",
  "homepage": "https://docs.aionis.work/plugins/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ostinatocc/aionis-sdk.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "verification",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "source:sync": "node scripts/runtime-source.mjs sync",
    "source:check": "node scripts/runtime-source.mjs check",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build --silent && tsx --test test/*.test.ts",
    "verify:trace-to-skill": "node verification/trace-to-skill-candidate.mjs",
    "prepack": "npm run source:check --silent && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
